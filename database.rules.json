{
  "rules": {
    "games": {
      "$game": {
        ".read": "auth != null",
        "hostUid": {
          ".write": "auth != null",
          ".validate": "newData.isString()"
        },
        "board": {
          ".write": "auth != null && data.parent().child('hostUid').val() == auth.uid"
        },
        "finalRound": {
          ".write": "auth != null && data.parent().child('hostUid').val() == auth.uid"
        },
        "gameState": {
          ".write": "auth != null && data.parent().child('hostUid').val() == auth.uid"
        },
        "picks": {
          ".write": "auth != null && data.parent().child('hostUid').val() == auth.uid"
        },
        "timer": {
          ".write": "auth != null && data.parent().child('hostUid').val() == auth.uid"
        },
        "players": {
          ".write": "auth != null",
          "$playerId": {
            "name": {
              ".validate": "newData.isString() && newData.val().length < 50"
            },
            "score": {
              ".validate": "newData.isNumber()"
            }
          }
        },
        "buzzes": {
          ".write": "auth != null"
        },
        "finals": {
          ".write": "auth != null"
        }
      }
    }
  }
}
