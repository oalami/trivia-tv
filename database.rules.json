{
  "rules": {
    "games": {
      "$game": {
        ".read": "auth != null",
        "board": {
          ".write": "auth != null"
        },
        "finalRound": {
          ".write": "auth != null"
        },
        "gameState": {
          ".write": "auth != null"
        },
        "picks": {
          ".write": "auth != null"
        },
        "timer": {
          ".write": "auth != null"
        },
        "players": {
          ".write": "auth != null",
          "$playerId": {
            "name": {
              ".validate": "newData.isString() && newData.val().length < 50"
            },
            "score": {
              ".validate": "newData.isNumber()"
            }
          }
        },
        "buzzes": {
          ".write": "auth != null"
        },
        "finals": {
          ".write": "auth != null"
        }
      }
    }
  }
}
